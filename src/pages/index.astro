---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import AvatarCallout from "../components/AvatarCallout.astro";
import TimeLine from "../components/TimeLine.astro";
import BlogPostCarousel from "../components/BlogPostCarousel.astro";
const workPosts = Object.values(import.meta.glob('../content/work/*.md', { eager: true }));
const blogPosts = Object.values(import.meta.glob('../content/blog/*.md', { eager: true }));
---

<BaseLayout pageTitle="Home"/>
<Hero title="Software Design for Impact" subtitle="Open to Opportunities">
</Hero>
<AvatarCallout imgUrl="https://thumbs.dreamstime.com/b/young-happy-man-thumbs-up-sign-casuals-isolated-white-background-38928366.jpg?w=768" quote="Hi! My name is Joey. I'm a Software Engineer with software generalist with 2+ years of experience overseeing design, development, and management of data-intensive systems.">
</AvatarCallout>
<TimeLine items={workPosts.map((post:any) => ({
	startDate: post.frontmatter.startDate,
	endDate: post.frontmatter.endDate,
	title: post.frontmatter.title,
	description: post.frontmatter.description
	}))}
/>
<BlogPostCarousel posts={blogPosts}
/>
</BaseLayout>