---
interface TimelineItem {
  startDate: string
  endDate?: string
  title: string
  description: string
  videoUrl?: string
}

interface Props {
    items: TimelineItem[]
}

const { items } = Astro.props;

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---
<section class="relative py-12 px-4">
  <!-- SVG line pinned to the left, full height of the section -->
  <svg class="absolute left-8 top-0 h-full w-px" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <line x1="0" y1="0" x2="0" y2="100%" stroke="#9ca3af" stroke-width="2"/>
  </svg>

  <ul class="space-y-10 pl-16">
    {items.map((item) => (
      <li class="relative">
        <!-- dot on the line -->
        <div class="absolute -left-[34px] top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-400"></div>
        <!-- callout card -->
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <span class="text-xs font-sans text-gray-400 uppercase tracking-wide float-right">
            {formatDate(item.startDate)} – {item.endDate ? formatDate(item.endDate) : 'Present'}
          </span>
          <h3 class="mt-1 text-xl font-serif">{item.title}</h3>
          <p class="mt-2 text-sm font-sans text-gray-600 leading-relaxed">{item.description}</p>
          {item.videoUrl && (
            <div class="mt-4 aspect-video">
                <iframe
                src={item.videoUrl}
                class="w-full h-full rounded"
                allowfullscreen
                />
            </div>
            )}
        </div>
      </li>
    ))}
  </ul>
</section>