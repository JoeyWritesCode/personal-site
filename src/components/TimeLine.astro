---
import Card from "../components/Card.astro";
interface TimelineItem {
  startDate: string
  endDate: string
  title: string
  description: string
  videoUrl?: string
}

interface Props {
    items: TimelineItem[]
}

const { items } = Astro.props;
const sortedItems = [...items].sort((a, b) => {
  const dateA = (a.endDate && a.endDate !== 'Present') ? new Date(a.endDate).getTime() : Infinity;
  const dateB = (b.endDate && b.endDate !== 'Present') ? new Date(b.endDate).getTime() : Infinity;
  return dateB - dateA;
});

const formatDate = (date: string) =>
  date === 'Present' ? 'Present' : new Date(date).toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'UTC' });
---
<section class="relative py-12 px-4">
  <!-- SVG line pinned to the left, full height of the section -->
  <svg class="absolute left-8 top-0 h-full w-px" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <line x1="0" y1="0" x2="0" y2="100%" stroke="#f97316" stroke-width="10"/>
  </svg>

  <ul class="space-y-10 pl-16">
    {sortedItems.map((item) => (
      <li class="relative">
        <!-- dot on the line -->
        <div class="absolute -left-[34px] top-2 w-3 h-3 rounded-full bg-white border-2 border-gray-400"></div>
        <!-- callout card -->
        <Card props={item}/>
      </li>
    ))}
  </ul>
</section>