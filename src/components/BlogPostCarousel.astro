---
import BlogPostCard from "../components/BlogPostCard.astro";
const { posts } = Astro.props;
---

<section class="w-full py-12 px-4">
  <h2 class="text-2xl font-semibold mb-8">Latest Writing</h2>

  <div class="relative">
    <div id="carousel-track" class="overflow-hidden">
      <div
        id="carousel-inner"
        class="flex transition-transform duration-300 ease-in-out"
        style="transform: translateX(0%)"
      >
        {posts.map((post: any) => (
            <BlogPostCard url={post.url} title={post.frontmatter.title} description={post.frontmatter.description}></BlogPostCard>
        ))}
      </div>
    </div>
  </div>
</section>
